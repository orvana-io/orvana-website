          <li><a href="https://github.com/orvana-io/orvana/issues" class="hover:text-white transition-colors">Issues</a></li>
          <li><a href="https://github.com/orvana-io/orvana/discussions" class="hover:text-white transition-colors">Discussions</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-600">
      <p>© {new Date().getFullYear()} Orvana. All rights reserved.</p>
