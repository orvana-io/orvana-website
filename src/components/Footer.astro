    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <div class="col-span-2 md:col-span-1">
        <div class="text-lg font-bold mb-3">Orvana</div>
        <p class="text-gray-500 text-sm leading-relaxed">
          Web-based radio playout software. Free for community stations. Pro for commercial broadcasters.
        </p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-gray-300 mb-3">Product</h4>
        <ul class="space-y-2 text-sm text-gray-500">
          <li><a href="#features" class="hover:text-white transition-colors">Features</a></li>
          <li><a href="#pricing" class="hover:text-white transition-colors">Pricing</a></li>
          <li><a href="https://docs.orvana.io" class="hover:text-white transition-colors">Documentation</a></li>
          <li><a href="https://docs.orvana.io/changelog" class="hover:text-white transition-colors">Changelog</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-gray-300 mb-3">Install</h4>
        <ul class="space-y-2 text-sm text-gray-500">
          <li><a href="https://docs.orvana.io/installation" class="hover:text-white transition-colors">Quick Start</a></li>
          <li><a href="https://github.com/orvana-io/orvana-docker" class="hover:text-white transition-colors">Docker</a></li>
