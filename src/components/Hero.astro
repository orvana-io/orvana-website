---
---

<section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-blue-950/30 via-gray-950 to-gray-950 pointer-events-none"></div>
  <!-- Subtle grid -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:64px_64px] pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/20 rounded-full px-4 py-1.5 text-sm text-blue-400 mb-8">
      <span class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"></span>
      Now in development — join the early access list
    </div>

    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-tight">
      Radio playout software<br />
      <span class="text-blue-400">that just works.</span>
    </h1>

    <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Orvana is a web-based radio automation platform for terrestrial and streaming stations.
      Run it on your own server. Access it from any browser. Rest easy knowing it's always in orbit.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="https://github.com/orvana-io/orvana"
        class="bg-white text-gray-950 font-semibold px-8 py-3.5 rounded-lg hover:bg-gray-100 transition-colors text-base"
      >
        View on GitHub
      </a>
      <a
        href="https://docs.orvana.io"
        class="bg-white/5 border border-white/10 text-white font-semibold px-8 py-3.5 rounded-lg hover:bg-white/10 transition-colors text-base"
      >
        Read the Docs
      </a>
    </div>

    <!-- Install command -->
    <div class="mt-12 inline-flex items-center gap-3 bg-gray-900 border border-white/10 rounded-lg px-6 py-3.5 font-mono text-sm">
      <span class="text-gray-500">$</span>
      <span class="text-green-400">curl -fsSL https://get.orvana.io | bash</span>
      <button
        onclick="navigator.clipboard.writeText('curl -fsSL https://get.orvana.io | bash')"
        class="text-gray-500 hover:text-white transition-colors ml-2"
        title="Copy to clipboard"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
        </svg>
      </button>
    </div>

    <p class="mt-3 text-xs text-gray-600">Requires Docker · Free for Core · $20/month for Pro</p>
  </div>
</section>
